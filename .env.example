# Copy to `.env` at the monorepo root for local dev. Do not commit `.env` or `.env*.local`.
#
# Production: set secrets in Vercel — `peacock-drivers` (root `artifacts/peacock-app`) holds
# `VITE_*` client vars; `peacock-api-server` (repo root) holds `DATABASE_URL`, `JWT_SECRET`,
# `FRONTEND_URL`, `STRIPE_SECRET_KEY`, etc. Use `vercel env pull` per project if you need a local snapshot.
#
# ─── Database ─────────────────────────────────────────────────────────────
# PostgreSQL connection string (Railway, Supabase, Neon, etc.)
DATABASE_URL=postgresql://user:password@host:5432/peacock_db

# ─── API Server ────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-here

# Frontend URL (for CORS and redirect links)
FRONTEND_URL=http://localhost:5173

# ─── Stripe ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Resend (Email) ────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@peacockdrivers.com

# ─── Google Maps ───────────────────────────────────────────────────────────
# Used in the frontend
NEXT_PUBLIC_GOOGLE_MAPS_KEY=AIza...

# ─── Exchange Rates (optional) ─────────────────────────────────────────────
# Get a free key at https://exchangerate-api.com
# If not set, fallback hardcoded rates are used
EXCHANGE_RATE_API_KEY=

# ─── Google Analytics 4 (optional) ────────────────────────────────────────
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
