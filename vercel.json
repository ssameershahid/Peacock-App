{
  "version": 2,
  "installCommand": "pnpm install --no-frozen-lockfile",
  "builds": [
    {
      "src": "artifacts/api-server/api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "artifacts/api-server/src/**",
          "lib/db/src/**",
          "lib/api-zod/src/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "artifacts/api-server/api/index.js"
    }
  ]
}
